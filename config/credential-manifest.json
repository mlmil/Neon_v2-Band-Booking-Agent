{
  "version": 1,
  "policy": "credential_parity",
  "agents": ["codex", "claude", "hermes"],
  "shared_environment_file": "/Volumes/VADER/Manifold/Neon_Blonde/Repos/Neon_v2/.secrets/neon-v2.env",
  "credentials": [
    {
      "id": "agentmail",
      "purpose": "Neon Blonde operational email",
      "required": true,
      "sources": [
        {"type": "env", "name": "AGENTMAIL_API_KEY"},
        {"type": "json_key", "path": "smtp_config.json", "key": "agentmail_api_key"}
      ]
    },
    {
      "id": "wordpress",
      "purpose": "Public show-card updates",
      "required": true,
      "sources": [
        {"type": "env", "name": "NEON_WP_USERNAME"},
        {"type": "env", "name": "NEON_WP_APP_PASSWORD"}
      ]
    },
    {
      "id": "google_calendar",
      "purpose": "Authenticated Neon Blonde calendar access",
      "required": true,
      "sources": [
        {"type": "file", "path": "/Users/studio_hub/.hermes/neon_oauth_token.json"},
        {"type": "file", "path": "/Users/studio_hub/.hermes/neon_client_secret.json"}
      ]
    },
    {
      "id": "groupme",
      "purpose": "GroupMe message sync",
      "required": false,
      "sources": [
        {"type": "env", "name": "GROUPME_TOKEN"},
        {"type": "file", "path": "/Users/studio_hub/.neon_blonde/groupme_token"},
        {"type": "json_key", "path": "smtp_config.json", "key": "groupme_token"}
      ]
    }
  ]
}
